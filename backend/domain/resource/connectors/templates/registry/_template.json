{
  "kind": "registry",
  "category": "Artifact",
  "description": "Reusable container or OCI registry connector profile.",
  "defaultAuthScheme": "basic",
  "capabilities": ["image-pull", "image-push", "oci"],
  "fields": [
    {
      "id": "endpoint",
      "label": "Endpoint",
      "type": "url",
      "required": true,
      "placeholder": "https://registry.example.com"
    },
    {
      "id": "credential",
      "label": "Credential",
      "type": "secret_ref",
      "secretTemplate": "basic_auth",
      "placeholder": "secretRef:..."
    }
  ]
}