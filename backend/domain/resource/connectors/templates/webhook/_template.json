{
  "kind": "webhook",
  "category": "Integration",
  "description": "Reusable webhook connector profile.",
  "defaultAuthScheme": "none",
  "capabilities": ["webhook"],
  "fields": [
    {
      "id": "endpoint",
      "label": "Endpoint",
      "type": "url",
      "required": true,
      "placeholder": "https://hooks.example.com/path"
    },
    {
      "id": "credential",
      "label": "Credential",
      "type": "secret_ref",
      "secretTemplate": "single_value",
      "placeholder": "secretRef:..."
    }
  ]
}