{
  "kind": "rest_api",
  "category": "Integration",
  "description": "Reusable HTTP integration connector profile.",
  "defaultAuthScheme": "none",
  "capabilities": ["http"],
  "fields": [
    {
      "id": "endpoint",
      "label": "Endpoint",
      "type": "url",
      "required": true,
      "placeholder": "https://api.example.com/v1"
    },
    {
      "id": "credential",
      "label": "Credential",
      "type": "secret_ref",
      "secretTemplate": "single_value",
      "placeholder": "secretRef:..."
    }
  ]
}