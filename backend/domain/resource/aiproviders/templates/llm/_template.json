{
  "kind": "llm",
  "category": "AI",
  "description": "Reusable AI provider profile.",
  "defaultAuthScheme": "api_key",
  "capabilities": ["chat"],
  "fields": [
    {
      "id": "endpoint",
      "label": "Endpoint",
      "type": "url",
      "required": true,
      "placeholder": "https://api.example.com/v1"
    },
    {
      "id": "credential",
      "label": "API Key",
      "type": "secret_ref",
      "required": true,
      "sensitive": true,
      "secretTemplate": "single_value",
      "placeholder": "secretRef:..."
    }
  ]
}